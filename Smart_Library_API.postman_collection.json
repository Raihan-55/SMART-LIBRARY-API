    {
      "name": "Authors",
      "item": [
        {
          "name": "Get All Authors",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/authors",
              "host": ["{{base_url}}"],
              "path": ["api", "authors"]
            },
            "description": "Mengambil semua data penulis"
          },
          "response": []
        },
        {
          "name": "Search Authors by Name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/authors?name=Haruki",
              "host": ["{{base_url}}"],
              "path": ["api", "authors"],
              "query": [
                {
                  "key": "name",
                  "value": "Haruki"
                }
              ]
